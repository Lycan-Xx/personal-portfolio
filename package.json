		"emailjs": "^4.0.3",
		"express": "^4.21.2",
		"framer-motion": "^12.5.0",
		"hugeicons-react": "^0.4.0",
		"lucide-react": "^1.8.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"react-icons": "^5.5.0",
		"react-intersection-observer": "^9.8.1",
		"react-scroll": "^1.9.3",
		"sweetalert2": "^11.16.0"
	},
	"devDependencies": {
		"@vitejs/plugin-react": "^4.2.1",
		"autoprefixer": "^10.4.21",
		"gh-pages": "^6.3.0",
