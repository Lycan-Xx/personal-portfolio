{
	"name": "personal-portfolio",
	"version": "1.0.0",
	"homepage": "https://Lycan-Xx.github.io/personal-portfolio",
	"description": "A clean and customizable ReactJS portfolio template for fellow developers. Credits to Jo Lienhoop!",
