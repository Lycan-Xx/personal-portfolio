{
	"name": "personal-portfolio",
	"version": "1.0.0",
	"homepage": "https://Lycan-Xx.github.io/personal-portfolio",
	"description": "A clean and customizable ReactJS portfolio template for fellow developers. Credits to Jo Lienhoop!",
	"repository": "https://github.com/Lycan-Xx/personal-portfolio",
	"author": "Mark Tan markcmtan@gmail.com",
	"contributor": "Lycan_Xx msbello514@gmail.com",
	"license": "MIT",
	"type": "module",



        "scripts": {
                "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:server\"",
                "dev:frontend": "vite",
                "dev:server": "node admin-server.js",
                "build": "vite build",
                "preview": "vite preview",
                "predeploy": "npm run build",
                "deploy": "gh-pages -d dist",
                "analyze": "vite build --mode analyze",
                "admin": "node admin-server.js",
                "build:cf": "vite build && npm run build:functions",
                "build:functions": "echo 'Note: For Cloudflare Pages, functions are built automatically'",
                "deploy:cf": "npm run build && npx wrangler pages deploy dist --project-name=personal-portfolio",
                "dev:cf": "concurrently \"npm run dev:frontend\" \"npm run dev:server\" \"npm run tunnel:cf\"",
                "tunnel:cf": "npx wrangler pages dev dist --project-name=personal-portfolio 2>/dev/null || echo 'Wrangler not installed. Install with: npm install -D wrangler'"
        }, 

	"dependencies": {
		"@emailjs/browser": "^4.4.1",
		"cors": "^2.8.5",
		"date-fns": "^4.1.0",
		"dotenv": "^16.4.7",
		"emailjs": "^4.0.3",
		"express": "^4.21.2",
		"framer-motion": "^12.5.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"react-icons": "^5.5.0",
		"react-intersection-observer": "^9.8.1",
		"react-scroll": "^1.9.3",
		"sweetalert2": "^11.16.0",
		"concurrently": "^8.2.2"
	},
	"devDependencies": {
		"@vitejs/plugin-react": "^4.2.1",
		"autoprefixer": "^10.4.21",
		"gh-pages": "^6.3.0",
		"postcss": "^8.5.3",
		"rollup-plugin-visualizer": "^5.14.0",
		"tailwindcss": "^3.3.3",
		"vite": "^5.1.0"
	}
}
